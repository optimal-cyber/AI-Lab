# Copy to terraform.tfvars and adjust. terraform.tfvars is git-ignored.
# All values below are the defaults — override only what you need.

project_name = "ai-lab"
region       = "us-east-1"

# Egress control. "proxy" = Squid allowlist (~$41/mo, default, ADR-009).
# "networkfirewall" = AWS Network Firewall (~$288/mo). Mutually exclusive.
egress_mode = "proxy"

# Cost knobs
instance_type       = "t3.small"  # app hosts
proxy_instance_type = "t3.micro"  # squid
root_volume_gb      = 30
log_retention_days  = 30

# Networking (single VPC, single active AZ for cost)
vpc_cidr           = "10.50.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b"]

# Egress allowlist — extend if you add providers/registries. Regional AWS
# service endpoints are appended automatically from `region`.
# egress_allowlist_domains = [".openai.com", ".anthropic.com", ...]
