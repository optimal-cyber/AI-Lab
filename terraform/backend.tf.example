# Remote Terraform state — ADR-017 (supersedes ADR-001). CONFIG-READY, NOT ACTIVE.
#
# Kept as `.example` so the current local-state workflow still `terraform init`s
# unchanged. To adopt remote state (required before provisioning real orgs, G3):
#   1. Create the bucket + lock table (bootstrap below).
#   2. `mv backend.tf.example backend.tf`  (uncomment the block).
#   3. `terraform init -migrate-state`
#
# terraform {
#   backend "s3" {
#     bucket         = "ai-lab-tfstate-317839577064" # versioned, SSE, public-access-blocked
#     key            = "ai-lab/terraform.tfstate"
#     region         = "us-east-1"
#     dynamodb_table = "ai-lab-tflock"               # LockID (string) hash key
#     encrypt        = true
#   }
# }
#
# --- bootstrap (chicken-and-egg: the bucket + table must exist first) ---------
# Create them once, out-of-band (these calls are idempotent enough for a one-off):
#
#   aws s3api create-bucket --bucket ai-lab-tfstate-317839577064 --region us-east-1
#   aws s3api put-bucket-versioning --bucket ai-lab-tfstate-317839577064 \
#     --versioning-configuration Status=Enabled
#   aws s3api put-bucket-encryption --bucket ai-lab-tfstate-317839577064 \
#     --server-side-encryption-configuration \
#     '{"Rules":[{"ApplyServerSideEncryptionByDefault":{"SSEAlgorithm":"AES256"}}]}'
#   aws s3api put-public-access-block --bucket ai-lab-tfstate-317839577064 \
#     --public-access-block-configuration \
#     BlockPublicAcls=true,IgnorePublicAcls=true,BlockPublicPolicy=true,RestrictPublicBuckets=true
#   aws dynamodb create-table --table-name ai-lab-tflock \
#     --attribute-definitions AttributeName=LockID,AttributeType=S \
#     --key-schema AttributeName=LockID,KeyType=HASH \
#     --billing-mode PAY_PER_REQUEST --region us-east-1
#
# Then migrate: mv backend.tf.example backend.tf && terraform init -migrate-state
