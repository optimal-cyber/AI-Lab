# =============================================================================
# .env.example — Zero Trust AI Lab (Optimal Labs)
# =============================================================================
# PLACEHOLDERS ONLY. Real values never live in this file or in Git.
#
# At runtime, docker/_shared/secrets-bootstrap.sh pulls the real values from
# AWS Secrets Manager (path prefix lab/*) into a tmpfs file and symlinks it as
# the compose-dir .env. This file documents the variable surface for each host
# so a reviewer can see what each stack consumes — it is not loaded directly.
#
# Two host roles consume two disjoint subsets:
#   AI_LAB_ROLE=chat     -> chat-host    (Open WebUI + cloudflared)
#   AI_LAB_ROLE=gateway  -> gateway-host (LiteLLM + Postgres + NeMo + MCP)
# =============================================================================

# ---- common (set by user-data / systemd, not from Secrets Manager) ----
AWS_DEFAULT_REGION=us-east-1
AI_LAB_ROLE=chat                       # chat | gateway
AI_LAB_COMPOSE=/opt/ai-lab/compose     # path to the compose dir for this host

# -----------------------------------------------------------------------------
# CHAT HOST  (role=chat)  — secrets sourced from: lab/*
# -----------------------------------------------------------------------------
# from lab/gateway_host_private_ip
LITELLM_HOST_IP=10.50.10.x
# from lab/litellm_virtual_key_webui  (legacy/optional — Open WebUI now uses the façade bootstrap key)
LITELLM_VIRTUAL_KEY_WEBUI=sk-REPLACE_ME
# from lab/gateway_bootstrap_key — the façade virtual key Open WebUI uses to call the gateway (:4001)
GATEWAY_BOOTSTRAP_KEY=sk-REPLACE_ME
# from lab/webui_secret
WEBUI_SECRET_KEY=REPLACE_ME
# from lab/cloudflare_tunnel_token_chat
CLOUDFLARE_TUNNEL_TOKEN=REPLACE_ME

# -----------------------------------------------------------------------------
# GATEWAY HOST  (role=gateway)  — secrets sourced from: lab/*
# -----------------------------------------------------------------------------
# provider keys (only the gateway host ever holds these)
OPENAI_API_KEY=sk-REPLACE_ME              # from lab/openai_api_key
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME       # from lab/anthropic_api_key
SAM_GOV_API_KEY=REPLACE_ME                # from lab/sam_gov_api_key

# LiteLLM core
LITELLM_MASTER_KEY=sk-REPLACE_ME          # from lab/litellm_master_key
LITELLM_SALT_KEY=REPLACE_ME               # from lab/litellm_salt_key
DATABASE_URL=postgresql://litellm:REPLACE_ME@postgres:5432/litellm
POSTGRES_PASSWORD=REPLACE_ME              # from lab/postgres_password

# LiteLLM admin OIDC (direct to Okta)
PROXY_BASE_URL=https://gateway.lab.optimallabs.io
OKTA_TENANT_URL=https://dev-REPLACE.okta.com        # from lab/okta_tenant_url
OKTA_LITELLM_CLIENT_ID=REPLACE_ME                   # from lab/okta_litellm_client_id
OKTA_LITELLM_CLIENT_SECRET=REPLACE_ME               # from lab/okta_litellm_client_secret

# gateway façade — control plane (ON; the façade is the front door). See operate.md.
GATEWAY_MASTER_KEY=sk-REPLACE_ME          # from lab/gateway_master_key    — admin API / /admin/ui (REQUIRED)
GATEWAY_BOOTSTRAP_KEY=sk-REPLACE_ME       # from lab/gateway_bootstrap_key — first-boot virtual key, Open WebUI + devs (REQUIRED)
GATEWAY_UPSTREAM_KEY=                     # from lab/gateway_upstream_key  — OPTIONAL; blank → falls back to LITELLM_MASTER_KEY

# cloudflared
CLOUDFLARE_TUNNEL_TOKEN=REPLACE_ME        # from lab/cloudflare_tunnel_token_gateway

# -----------------------------------------------------------------------------
# Okta — Cloudflare Access app (consumed in the Cloudflare dashboard / TF, not here)
# -----------------------------------------------------------------------------
# lab/okta_cf_client_id
# lab/okta_cf_client_secret
